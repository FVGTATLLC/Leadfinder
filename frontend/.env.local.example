# =============================================================================
# SalesPilot Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.

# --- NextAuth.js ---
# The canonical URL of your frontend (used by NextAuth for callbacks)
NEXTAUTH_URL=http://localhost:3000
# A random secret used to encrypt JWT tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=change-me-in-production

# --- Backend API ---
# The full URL of the FastAPI backend API.
# Local development: http://localhost:8000/api/v1
# Production (Vercel): Set this to your Cloud Run backend URL, e.g.
#   https://salespilot-backend-xxxxxx-uc.a.run.app/api/v1
#
# NOTE: On Vercel, browser-side API calls use a relative path (/api/v1/*)
# which is proxied to this URL via Next.js rewrites. This avoids CORS issues.
# Server-side calls (SSR, auth) use this variable directly.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
